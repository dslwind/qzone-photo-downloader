# Declare files that should always be treated as text and ensure LF line endings.
# This prevents issues with line endings across different operating systems.

*.py text eol=lf
*.sh text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
LICENSE text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf

# Common Python project files.
Pipfile text eol=lf
Pipfile.lock text eol=lf
pyproject.toml text eol=lf
requirements.txt text eol=lf
setup.py text eol=lf

# Fallback: let Git auto-detect other text files.
* text=auto

# Binary files should not be diffed or merged as text.
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.svg binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.sqlite binary
*.lock binary
*.pkl binary
*.hdf5 binary
*.parquet binary
*.onnx binary

# Help GitHub/GitLab language statistics.
/dist/* linguist-generated=true
/build/* linguist-generated=true
/docs/_build/* linguist-generated=true
